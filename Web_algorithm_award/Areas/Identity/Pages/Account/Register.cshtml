@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<style>
    .auth-wrapper {
        background: linear-gradient(135deg, #74ebd5 0%, #9face6 100%);
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        border-radius: 15px;
        margin-top: 2rem;
        margin-bottom: 2rem;
    }

    .auth-card {
        background: #ffffff;
        padding: 3rem 2.5rem;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        width: 100%;
        max-width: 550px;
    }

    .auth-title {
        color: #2c3e50;
        font-weight: 800;
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .auth-subtitle {
        text-align: center;
        color: #7f8c8d;
        margin-bottom: 2rem;
    }

    .btn-gradient {
        background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%);
        border: none;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 242, 254, 0.4);
            color: white;
        }

    .form-floating .form-control:focus {
        border-color: #4facfe;
        box-shadow: 0 0 0 0.25rem rgba(79, 172, 254, 0.25);
    }

    .login-link {
        color: #4facfe;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
    }

        .login-link:hover {
            color: #00f2fe;
            text-decoration: underline;
        }
</style>

<div class="auth-wrapper">
    <div class="auth-card">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2 class="auth-title">Tạo tài khoản mới 🚀</h2>
            <p class="auth-subtitle">Điền thông tin bên dưới để tham gia với chúng tôi</p>

            <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Name" class="form-control" autocomplete="name" aria-required="true" placeholder="Nguyễn Minh" />
                <label asp-for="Input.Name">Họ và tên</label>
                <span asp-validation-for="Input.Name" class="text-danger text-sm"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger text-sm"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password">Mật khẩu</label>
                        <span asp-validation-for="Input.Password" class="text-danger text-sm"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="confirmpassword" />
                        <label asp-for="Input.ConfirmPassword">Nhập lại mật khẩu</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger text-sm"></span>
                    </div>
                </div>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.HomeAddress" class="form-control" aria-required="true" placeholder="HomeAddress" />
                <label asp-for="Input.HomeAddress">Địa chỉ</label>
                <span asp-validation-for="Input.HomeAddress" class="text-danger text-sm"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Input.PostalCode" class="form-control" aria-required="true" placeholder="PostalCode" />
                <label asp-for="Input.PostalCode">Mã bưu điện</label>
                <span asp-validation-for="Input.PostalCode" class="text-danger text-sm"></span>
            </div>
            <div class="mb-3">
                <label class="custom-form-label">Nhập mã captcha</label>
                <div class="captcha-area">
                    <div class="d-flex align-items-center">

                        <img id="img-captcha" src="/get-captcha-image" alt="Captcha" class="border rounded me-2"
                             style="cursor: pointer;" title="Nhấn vào đây để tải lại mã khác"
                             onclick="this.src = '/get-captcha-image?' + new Date().getTime();" />

                        <input type="text" name="UserCaptchaCode" class="custom-input form-control" autocomplete="off" required />

                    </div>

                    @if (ViewData.ModelState["UserCaptchaCode"]?.Errors.Count > 0)
                    {
                        <span class="text-danger small d-block mt-1">
                            @ViewData.ModelState["UserCaptchaCode"].Errors[0].ErrorMessage
                        </span>
                    }
                </div>
            </div>
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-gradient rounded-pill">Đăng ký ngay</button>

            <div class="text-center mt-4">
                <p class="text-muted mb-0">
                    Đã có tài khoản?
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="login-link">Đăng nhập ngay</a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}