@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    .login-wrapper {
        background: linear-gradient(135deg, #74ebd5 0%, #9face6 100%);
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        border-radius: 15px;
        margin-top: 2rem;
        margin-bottom: 2rem;
    }

    .login-card {
        background: #ffffff;
        padding: 3rem 2.5rem;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        width: 100%;
        max-width: 450px;
    }

    .login-title {
        color: #2c3e50;
        font-weight: 800;
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .login-subtitle {
        text-align: center;
        color: #7f8c8d;
        margin-bottom: 2rem;
    }

    .btn-gradient {
        background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%);
        border: none;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-gradient:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 242, 254, 0.4);
        color: white;
    }

    .form-floating .form-control:focus {
        border-color: #4facfe;
        box-shadow: 0 0 0 0.25rem rgba(79, 172, 254, 0.25);
    }

    .register-link {
        color: #4facfe;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
    }

    .register-link:hover {
        color: #00f2fe;
        text-decoration: underline;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <section>
            <form id="account" method="post">
                <h2 class="login-title">Chào mừng trở lại! 👋</h2>
                <p class="login-subtitle">Vui lòng đăng nhập để tiếp tục</p>

                <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger text-sm"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger text-sm"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMe" />
                        <label class="form-check-label text-muted" for="rememberMe">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                </div>

                <div class="mb-3">
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-gradient rounded-pill">Đăng nhập</button>
                </div>

                <div class="text-center mt-4">
                    <p class="text-muted mb-0">
                        Chưa có tài khoản?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="register-link">Đăng kí ngay</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}