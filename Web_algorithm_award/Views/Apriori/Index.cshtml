@{
    ViewData["Title"] = "Thuật toán Apriori";
}

<style>
    /* Kế thừa phong cách từ Đăng nhập / Đăng ký */
    .apriori-wrapper {
        background: linear-gradient(135deg, #74ebd5 0%, #9face6 100%);
        min-height: 80vh;
        display: flex;
        align-items: flex-start; /* Để form không bị tụt xuống giữa khi có nhiều kết quả */
        justify-content: center;
        padding: 3rem 1rem;
        border-radius: 15px;
        margin-top: 2rem;
        margin-bottom: 2rem;
    }

    .apriori-card {
        background: #ffffff;
        padding: 3rem 2.5rem;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        width: 100%;
        max-width: 800px; /* Rộng hơn form login để chứa bảng dữ liệu */
        transition: all 0.3s ease;
    }

    .apriori-title {
        color: #2c3e50;
        font-weight: 800;
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .apriori-subtitle {
        text-align: center;
        color: #7f8c8d;
        margin-bottom: 2.5rem;
    }

    .btn-gradient {
        background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%);
        border: none;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 242, 254, 0.4);
            color: white;
        }

    .form-floating .form-control:focus, .form-control:focus {
        border-color: #4facfe;
        box-shadow: 0 0 0 0.25rem rgba(79, 172, 254, 0.25);
    }

    /* Tinh chỉnh khu vực chọn file */
    .file-upload-box {
        border: 2px dashed #ced4da;
        border-radius: 15px;
        padding: 1.5rem;
        background-color: #f8f9fa;
        transition: all 0.3s;
    }

        .file-upload-box:hover, .file-upload-box:focus-within {
            border-color: #4facfe;
            background-color: #f0faff;
        }

    /* Bo góc cho bảng kết quả */
    .table-custom-wrapper {
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    /* CSS cho thanh cuộn AI */
    .ai-scroll {
        max-height: 300px;
        overflow-y: auto;
    }

        .ai-scroll::-webkit-scrollbar {
            width: 8px;
        }

        .ai-scroll::-webkit-scrollbar-thumb {
            background: #4facfe; /* Đổi màu thanh cuộn đồng bộ với theme */
            border-radius: 4px;
        }

        .ai-scroll::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

    .ai-text {
        white-space: pre-wrap;
        font-family: inherit;
        margin: 0;
        color: #2c3e50;
    }
</style>

<div class="apriori-wrapper">
    <div class="apriori-card">

        <h2 class="apriori-title">📊 Thuật toán Apriori</h2>
        <p class="apriori-subtitle">Khám phá các tập phổ biến từ tệp dữ liệu của bạn</p>

        <form asp-action="UploadFile" method="post" enctype="multipart/form-data">

            <div class="d-flex justify-content-end mb-2">
                <a href="~/FileSample/sample.svm" class="btn btn-sm btn-outline-info rounded-pill" download>
                    📥 Tải file mẫu .SVM
                </a>
            </div>

            <div class="file-upload-box mb-4">
                <label class="form-label fw-bold text-secondary">📂 Chọn File dữ liệu (.SVM)</label>
                <input type="file" name="file" class="form-control bg-white" required />
            </div>

            <div class="form-floating mb-4">
                <input type="number" name="minSupport" class="form-control" step="any" min="0" max="1" placeholder="0.5" required />
                <label>📊 Min Support (> 0 và <= 1)</label>
            </div>

            <button type="submit" class="w-100 btn btn-lg btn-gradient rounded-pill">
                🚀 Thực thi thuật toán
            </button>

        </form>

        @if (ViewBag.FrequentItemsets != null)
        {
            <hr class="my-5" style="border-top: 2px dashed #e9ecef; opacity: 1;">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0 text-dark fw-bold">📈 Kết quả phân tích</h4>
                <span class="badge bg-primary rounded-pill px-3 py-2">
                    Tổng số tập phổ biến: @ViewBag.TotalItemsets
                </span>
            </div>

            <div class="table-custom-wrapper mb-4">
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-hover mb-0" style="table-layout: fixed; width: 100%;">
                        <thead style="background-color: #2c3e50; color: white; position: sticky; top: 0; z-index: 1;">
                            <tr>
                                <th style="width:75%; padding: 1rem;">🛒 Itemset</th>
                                <th style="width:25%; padding: 1rem; text-align: center;">📊 Support</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.FrequentItemsets)
                            {
                                <tr>
                                    <td style="word-wrap:break-word; padding: 1rem; vertical-align: middle;">
                                        @string.Join(", ", item.Itemset)
                                    </td>
                                    <td style="text-align: center; vertical-align: middle;">
                                        <span class="badge" style="background-color: #e9f7fe; color: #4facfe; font-size: 0.9rem;">
                                            @item.Support
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (ViewBag.AIExplanation != null)
            {
                <div class="card border-0 shadow-sm" style="border-radius: 15px; background: #f8fcfd; border-left: 5px solid #4facfe !important;">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3" style="color: #4facfe;">🤖 AI Giải thích</h5>
                        <div class="ai-scroll pe-2">
                            <pre class="ai-text">@ViewBag.AIExplanation</pre>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Message"] != null)
    {
        var message = TempData["Message"]!.ToString();
        var isError = message.ToLower().Contains("lỗi") || message.ToLower().Contains("error");
        var iconType = isError ? "error" : "success";

        <script>
            document.addEventListener("DOMContentLoaded", function() {
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3500,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                Toast.fire({
                    icon: '@iconType',
                    title: '@Html.Raw(message)'
                });
            });
        </script>
    }
}